# ── DATABASE ──────────────────────────────────────────────
# Get a free MongoDB URI from https://www.mongodb.com/atlas
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/diabeats?retryWrites=true&w=majority

# ── AUTH ──────────────────────────────────────────────────
# Any long random string for signing JWT tokens
JWT_SECRET=diabeats_super_secret_key_change_this_in_production_2024

# ── SERVER ────────────────────────────────────────────────
PORT=5000

# ── ANTHROPIC (optional — for server-side AI calls) ───────
# Paste your Anthropic API key here to proxy AI calls securely
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
